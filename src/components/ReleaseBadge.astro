---
import versionMeta from '../version.json';

const prereleaseChannel = versionMeta.version.includes('-')
  ? versionMeta.version.split('-')[1]?.split('.')[0]
  : undefined;
const prereleaseLabel = prereleaseChannel === 'beta' ? 'Beta' : 'Pre-release';
---

<span class="release-badge">
  <code>v{versionMeta.version}</code>
  {prereleaseChannel && <strong>{prereleaseLabel}</strong>}
  <span class="release-date">released {versionMeta.releaseDate}</span>
</span>

<style>
  .release-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    font-size: 13px;
  }
  .release-date {
    color: var(--sl-color-gray-2);
  }
</style>
